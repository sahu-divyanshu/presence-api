{
    "name": "Presence API Dev",
    "image": "mcr.microsoft.com/devcontainers/python:3.12-bullseye",
    "forwardPorts": [
        8000,
        6379
    ],
    "postCreateCommand": "pip install -r requirements.txt",
    "runArgs": [
        "--network=host"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "rangav.vscode-thunder-client"
            ]
        }
    }
}